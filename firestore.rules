rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Default Safety Net: Deny-all by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "Mohdaslamshah987@gmail.com" && 
             request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // 2. Validation Blueprints (Anti-Update-Gap / Anti-Poisoning)
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'phone', 'location', 'timestamp', 'source']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 30 &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 500 &&
             (data.email == null || (data.email is string && data.email.size() <= 254)) &&
             (data.serviceInterest == null || (data.serviceInterest is string && data.serviceInterest.size() <= 200)) &&
             (data.message == null || (data.message is string && data.message.size() <= 2000)) &&
             data.source is string && data.source.size() <= 100;
    }
    
    function isValidBooking(data) {
      return data.keys().hasAll(['name', 'phone', 'location', 'selectedPlan', 'timestamp', 'source']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 30 &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 500 &&
             data.selectedPlan is string && data.selectedPlan.size() > 0 && data.selectedPlan.size() <= 200 &&
             (data.email == null || (data.email is string && data.email.size() <= 254)) &&
             (data.notes == null || (data.notes is string && data.notes.size() <= 2000)) &&
             data.source is string && data.source.size() <= 100;
    }
    
    function isValidTrialRequest(data) {
      return data.keys().hasAll(['name', 'phone', 'location', 'timestamp', 'source']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 30 &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 500 &&
             (data.email == null || (data.email is string && data.email.size() <= 254)) &&
             (data.notes == null || (data.notes is string && data.notes.size() <= 2000)) &&
             data.source is string && data.source.size() <= 100;
    }
    
    // 6. Split / Secure Collections Matching with strict permissions
    match /leads/{leadId} {
      allow create: if isValidLead(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
    
    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
    
    match /trial_requests/{requestId} {
      allow create: if isValidTrialRequest(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

match /iram_messages/{messageId} {
  allow create: if true;
  allow read, update, delete: if isAdmin();
}
match /chat_sessions/{sessionId} {
  allow create: if true;
  allow read: if true;
  allow update: if true;
  allow delete: if isAdmin();
}

  }
}
